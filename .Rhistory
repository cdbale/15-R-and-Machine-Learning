for (i in 1:10) {
print(i)
}
# create empty vector
empty_vector <- vector(mode = "double", length = 7)
# fill in the vector,
for (i in seq_along(empty_vector)) {
empty_vector[i] <- 1 + i
}
empty_vector
empty_vector <- vector(mode = "double", length = 7)
for (i in seq_along(empty_vector)) {
if (i == 1) {
empty_vector[i] <- 1
} else {
empty_vector[i] <- 1 + empty_vector[i - 1]
}
}
empty_vector
empty_vector <- vector(mode = "double", length = 7)
for (i in seq_along(empty_vector)) {
if (i == 1) {
empty_vector[i] <- 1
} else {
empty_vector[i] <- 2 * empty_vector[i - 1]
}
}
empty_vector
empty_vector <- vector(mode = "double", length = 7)
for (i in seq_along(empty_vector)) {
if (i == 1) {
empty_vector[i] <- 1
} else {
empty_vector[i] <- empty_vector[1:(i - 1)]
}
}
empty_vector
empty_vector <- vector(mode = "double", length = 7)
for (i in seq_along(empty_vector)) {
if (i == 1) {
empty_vector[i] <- 1
} else {
empty_vector[i] <- sum(empty_vector[1:(i - 1)])
}
}
empty_vector
4 %% 2
empty_vector <- vector(mode = "double", length = 10)
for (i in seq_along(empty_vector)) {
if (i %% 2 == 0) {
empty_vector[i] <- 0
} else {
empty_vector[i] <- i
}
}
empty_vector
